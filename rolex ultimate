import math
import tkinter as tk
import datetime as dt

# Window setup
win = tk.Tk()
win.title("moj rolex")
canvas = tk.Canvas(win, width=800, height=800, bg="white")
canvas.pack()

# Clock geometry
CX, CY          = 400, 400
RADIUS          = 200
HOUR_LEN        = 100
MINUTE_LEN      = 150
SECOND_LEN      = 170
NUMBER_RADIUS   = RADIUS - 30

# Hand widths
HOUR_WIDTH      = 6
MINUTE_WIDTH    = 3
SECOND_WIDTH    = 1


def hand_coords(angle_deg, length):
    """Return (x, y) endpoint for a clock hand given angle in degrees."""
    rad = math.radians(angle_deg - 90)
    return CX + length * math.cos(rad), CY + length * math.sin(rad)


def draw():
    canvas.delete("all")
    now = dt.datetime.now()

    # Face
    canvas.create_oval(
        CX - RADIUS, CY - RADIUS,
        CX + RADIUS, CY + RADIUS,
        outline="black", width=3
    )

    # Hour numbers
    for h in range(1, 13):
        x, y = hand_coords(h * 30, NUMBER_RADIUS)
        canvas.create_text(x, y, text=str(h), font=("Arial", 14, "bold"))

    # Hour hand
    hx, hy = hand_coords(now.hour % 12 * 30 + now.minute * 0.5, HOUR_LEN)
    canvas.create_line(CX, CY, hx, hy, width=HOUR_WIDTH)

    # Minute hand
    mx, my = hand_coords(now.minute * 6, MINUTE_LEN)
    canvas.create_line(CX, CY, mx, my, width=MINUTE_WIDTH)

    # Second hand
    sx, sy = hand_coords(now.second * 6, SECOND_LEN)
    canvas.create_line(CX, CY, sx, sy, width=SECOND_WIDTH, fill="red")

    # Center dot
    canvas.create_oval(CX - 4, CY - 4, CX + 4, CY + 4, fill="black")

    canvas.after(1000, draw)

draw()
win.mainloop()
